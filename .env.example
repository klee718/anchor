GEMINI_API_KEY=

# --- Vercel Hosting & Gatekeeper ---
# Set VERCEL_HOSTING=TRUE to enable manual whitelist authentication for Vercel preview testing.
VERCEL_HOSTING=
# Optional: comma-separated email:password list (overrides or complements users.txt file)
# Example: ALLOWED_USERS=guest@example.com:anchor2026,friend@example.com:secret123
ALLOWED_USERS=

# --- Firebase Auth (client) ---
# From Firebase Console > Project Settings > General > Your apps > Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- Firebase Admin (server) ---
# Firebase Console > Project Settings > Service Accounts > Generate new private key.
# Paste the ENTIRE downloaded JSON file contents here, minified to one line.
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Stripe ---
# Stripe Dashboard > Developers > API keys (use a test-mode secret key while developing)
STRIPE_SECRET_KEY=
# Stripe Dashboard > Products > create a $5.99/mo recurring price, copy its price ID (price_...)
STRIPE_PRICE_ID=
# Stripe Dashboard > Developers > Webhooks > add endpoint (.../api/stripe/webhook) > signing secret
STRIPE_WEBHOOK_SECRET=
# Optional: only needed if you add Stripe.js client-side elements later; not required for Checkout redirect.
VITE_STRIPE_PUBLISHABLE_KEY=
VERCEL_HOSTING=
DRY_RUN=
rules_version = '2';

// All reads/writes to Firestore go through the authenticated server routes
// (server.ts uses the Admin SDK, which bypasses these rules entirely). The
// client never talks to Firestore directly, so direct client access is
// denied outright — this is a deny-by-default backstop, not the primary
// access control (that's Firebase Auth + requireAuth in firebase-admin.ts).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
